import discord

# Create the interactive view
class TicketView(discord.ui.View):
    def __init__(self):
        super().__init__(timeout=None)

    @discord.ui.button(label="Guidelines", style=discord.ButtonStyle.gray, custom_id="guide_btn", emoji="📋")
    async def guidelines(self, interaction: discord.Interaction, button: discord.ui.Button):
        await interaction.response.send_message("Guideline text here.", ephemeral=True)

    @discord.ui.select(placeholder="Choose a Ticket Category", custom_id="ticket_sel", options=[
        discord.SelectOption(label="Support", emoji="❓"),
        discord.SelectOption(label="Report", emoji="⚠️")
    ])
    async def select_category(self, interaction: discord.Interaction, select: discord.ui.Select):
        await interaction.response.send_message(f"Selected: {select.values[0]}", ephemeral=True)

