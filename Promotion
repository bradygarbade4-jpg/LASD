const { AttachmentBuilder, EmbedBuilder } = require('discord.js');
const Canvas = require('canvas');

const canvas = Canvas.createCanvas(1200, 675);
const ctx = canvas.getContext('2d');

// Background
const background = await Canvas.loadImage('./promotion-bg.png');
ctx.drawImage(background, 0, 0, canvas.width, canvas.height);

// Text
ctx.font = 'bold 60px Arial';
ctx.fillStyle = '#ffffff';
ctx.fillText('Promotion #67', 50, 100);

ctx.font = '36px Arial';
ctx.fillText('Congratulations John!', 50, 180);

// Save image
const attachment = new AttachmentBuilder(
    canvas.toBuffer(),
    { name: 'promotion.png' }

const embed = new EmbedBuilder()
  .setTitle('Promotion #67')
  .setImage('attachment://promotion.png');

channel.send({
  embeds: [embed],
  files: [attachment]
});
